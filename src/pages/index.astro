---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import { groupTranslations } from '../lib/posts.js';

const all = await getCollection('posts', ({ data }) => !data.draft);
const items = groupTranslations(all, 'es');
---

<Base>
  <section class="hero">
    <span class="eyebrow">Blog sobre ServiceNow</span>
    <h1>Notas de plataforma sobre <span class="accent">ServiceNow</span></h1>
    <p>
      Comparativas, scripting, arquitectura y novedades de la plataforma.
      Aprendizajes de proyecto explicados sin relleno — en español e inglés.
    </p>
  </section>

  <div class="section-head">
    <h2>Últimos artículos</h2>
    <a href="/tags/">Ver por temas →</a>
  </div>

  <ul class="post-list">
    {items.map((item, i) => (
      <PostCard post={item.post} langs={item.langs} featured={i === 0} />
    ))}
  </ul>
</Base>
